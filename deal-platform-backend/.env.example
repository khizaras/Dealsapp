# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=deal_platform
DB_USER=root
DB_PASSWORD=your_password
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Redis Configuration (for caching and queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@dealplatform.com

# AWS Configuration (for S3 image storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=deal-platform-images

# Affiliate API Keys
BESTBUY_API_KEY=your-bestbuy-api-key
EBAY_APP_ID=your-ebay-app-id
EBAY_CERT_ID=your-ebay-cert-id
EBAY_REDIRECT_URI=your-ebay-redirect-uri
WALMART_API_KEY=your-walmart-api-key
TARGET_API_KEY=your-target-api-key
AMAZON_ACCESS_KEY=your-amazon-access-key
AMAZON_SECRET_KEY=your-amazon-secret-key
AMAZON_ASSOCIATE_TAG=your-amazon-associate-tag

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-in-production

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# Queue Configuration
BULL_QUEUE_PREFIX=deal_platform
BULL_JOB_ATTEMPTS=3
BULL_JOB_BACKOFF=5000

# Price Sync Configuration
PRICE_SYNC_INTERVAL_MINUTES=15
DEAL_VERIFICATION_INTERVAL_MINUTES=30
ALERT_CHECK_INTERVAL_MINUTES=10

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# Socket.IO Configuration
SOCKET_CORS_ORIGIN=http://localhost:3001

# Pagination Defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Image Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Deal Scoring Weights
WEIGHT_UPVOTES=1.0
WEIGHT_DOWNVOTES=-0.5
WEIGHT_COMMENTS=0.3
WEIGHT_CLICKS=0.2
WEIGHT_AGE_DECAY=0.1
